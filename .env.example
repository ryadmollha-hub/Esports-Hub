# ─── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (provisioned by Replit Database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-use-a-long-random-string-here

# ─── Admin Panel Credentials ────────────────────────────────────────────────────
# These three values form the admin authentication token
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password
ADMIN_SECRET=your-admin-secret-key

# ─── API Server ─────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── Frontend ───────────────────────────────────────────────────────────────────
# Vite dev server port
# PORT=24250  (set by workflow)
# BASE_PATH=/  (set by workflow)

# ─── Optional ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (leave blank to allow all in dev)
# ALLOWED_ORIGIN=https://yourapp.replit.app

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
