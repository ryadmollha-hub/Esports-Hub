# ══════════════════════════════════════════════════════════════════════════════
# FF Arena — Environment Variables Reference
# Copy to .env (never commit .env) and fill in real values.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# • Replit:  injected automatically by the built-in Postgres add-on.
# • Render:  set in the service dashboard → Environment.
# • Local:   postgresql://user:password@localhost:5432/ff_arena
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Used to sign & verify user auth tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# On Render this is auto-generated via render.yaml (generateValue: true).
JWT_SECRET=change-me-use-a-long-random-string-in-production

# ─── Admin credentials ────────────────────────────────────────────────────────
# These three values form the admin authentication token.
# ADMIN_SECRET is also auto-generated by render.yaml.
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_SECRET=change-me-to-a-random-secret-key

# ─── API Server ───────────────────────────────────────────────────────────────
# Port the Express server listens on.
# • Development: 8080  (set by workflow)
# • Render:      10000 (set in render.yaml)
PORT=8080

# Node environment — always "production" in deployed environments.
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave blank in development (allows all origins).
# Example: https://ff-arena.vercel.app,https://ff-arena.netlify.app
ALLOWED_ORIGIN=

# ─── Logging ──────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Frontend (set these in Vercel / Netlify dashboard, NOT here) ─────────────
# URL of your deployed Express API (no trailing slash).
# Only required when frontend is hosted separately from the backend.
# VITE_API_URL=https://ff-arena-api.onrender.com
