modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24250
externalPort = 3000

[userenv]

[userenv.shared]
API_PORT = "8080"
BASE_PATH = "/"
PORT = "5000"

[nix]
channel = "stable-25_05"
