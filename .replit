modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ artifacts/freefire-tournament/node_modules/.bin/vite --config artifacts/freefire-tournament/vite.config.ts --host 0.0.0.0"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24250
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
BASE_PATH = "/"
JWT_SECRET = "0b8cb7f78c149cec7a2e26a19a76492ead7944b79a3f19b0cbf361559d8064f6010c3d0c2fb81b3b67e1adf3200f7b6201c8d8e112b5e27323ed224b8c25ea70"
