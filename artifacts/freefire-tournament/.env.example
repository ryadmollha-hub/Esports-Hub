# ─── Netlify / production env vars ───────────────────────────────────────────
# Copy this file to .env.local for local overrides (never commit .env.local).

# URL of your deployed Express API server (no trailing slash).
# Required when the frontend is hosted separately from the backend (e.g. Netlify).
# Example: https://ff-arena-api.onrender.com
VITE_API_URL=

# ─── Backend (api-server) env vars ───────────────────────────────────────────
# These are set on the server that runs the Express API, NOT in Netlify.
DATABASE_URL=
JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SECRET=
# Allow requests from your Netlify domain (comma-separated)
ALLOWED_ORIGIN=https://your-site.netlify.app
